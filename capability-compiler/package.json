{
  "name": "@zak/capability-compiler",
  "version": "0.1.0",
  "description": "Compile structured capability worksheets → registry definitions, hashes, golden tests",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cap-compile": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "compile:hai-time": "node dist/cli.js compile ../capabilities/hai.time.get/worksheet.yaml --out ../capabilities",
    "pretest": "npm run build",
    "test": "vitest run",
    "verify": "npm run build && node dist/cli.js verify ../capabilities"
  },
  "dependencies": {
    "@zak/capability-registry": "file:../capability-registry",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "semver": "^7.6.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "ISC"
}
