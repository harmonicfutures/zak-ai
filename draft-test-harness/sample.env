# Copy to .env in this directory and fill in (never commit .env).
#
# --- OpenRouter (testing / free models) ---
# If OPENROUTER_API_KEY is set, the harness uses OpenRouter for all LLM calls
# (chat completions). Default model: openrouter/free (see OpenRouter docs).
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://github.com/harmonicfutures/zak-ai
# OPENROUTER_APP_TITLE=ZAKAI-draft-test-harness

# --- OpenAI (when OPENROUTER_API_KEY is unset) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Shared ---
# ZAK_CONSTITUTION_ID=zak-default
# PORT=3000
